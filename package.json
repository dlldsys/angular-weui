{
  "name": "angular-weui-components",
  "version": "0.1.0-alpha.3",
  "description": "Angular WeUI component library - WeChat UI components for Angular applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build angular-weui --configuration production && npm run build:package",
    "build:package": "mkdir -p dist/angular-weui && cp public_api.ts dist/angular-weui/index.ts && cp README.md dist/angular-weui/ && cp LICENSE dist/angular-weui/ && cp package.lib.json dist/angular-weui/package.json",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:performance": "ng build && echo 'Performance testing guide created. Open performance-test.ts in browser console.'",
    "test:memory": "echo 'Run performanceTests.memory() in browser console'",
    "test:components": "echo 'Run performanceTests.runAll() in browser console'",
    "storybook": "ng run angular-weui:storybook",
    "build-storybook": "ng run angular-weui:build-storybook",
    "publish:npm": "npm run build:package && cd dist/angular-weui && npm publish"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "angular",
    "weui",
    "wechat",
    "ui",
    "components",
    "mobile",
    "typescript"
  ],
  "author": "dlldsys",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dlldsys/angular-weui.git"
  },
  "bugs": {
    "url": "https://github.com/dlldsys/angular-weui/issues"
  },
  "homepage": "https://dlldsys.github.io/angular-weui/",
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "weui": "^2.6.26"
  },
  "devDependencies": {
    "@angular-devkit/architect": "^0.2102.0",
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular-devkit/core": "^21.2.0",
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@compodoc/compodoc": "^1.2.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/angular": "^10.3.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "storybook": "^10.3.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
